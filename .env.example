# OpenAI API Key (required if clients don't send their own key)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional access code; clients use "Bearer ak-<your-code>" when set
ACCESS_CODE=

# Upstream OpenAI API base URL (default: api.openai.com)
BASE_URL=api.openai.com

# Protocol for BASE_URL when it has no scheme (default: https)
PROTOCOL=https

# Optional OpenAI organization ID
OPENAI_ORG_ID=

# Default model when request body omits model (optional)
DEFAULT_MODEL=gpt-5.5

# Comma-separated allowed models; empty = allow all
ALLOWED_MODELS=gpt-5.5,gpt-5.5-pro,gpt-5.5-2026-04-23
